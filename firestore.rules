// ============================================================
//  ELLECTRA AUTOMATION — FIRESTORE SECURITY RULES
//  Paste this into Firebase Console > Firestore > Rules tab
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── ORDERS COLLECTION ────────────────────────────────────
    match /orders/{orderId} {

      // PUBLIC: Anyone can CREATE an order (customers placing orders)
      allow create: if
        request.resource.data.keys().hasAll(['name','phone','email','version','status','installationBooked','createdAt'])
        && request.resource.data.status == 'pending'   // new orders must start as 'pending'
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.email is string
        && request.resource.data.email.matches('.*@.*\\..*')
        && request.resource.data.phone is string
        && request.resource.data.version in ['V1', 'V2', 'V3'];

      // AUTHENTICATED ADMIN ONLY: Read + Update orders
      allow read, update, delete: if request.auth != null;

      // No public reads (protect customer data)
      allow read: if request.auth != null;
    }

    // ─── ADMIN COLLECTION (optional, for admin metadata) ──────
    match /admins/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── DENY ALL ELSE ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// ============================================================
//  SETUP INSTRUCTIONS
// ============================================================
//
//  1. Go to Firebase Console → Your Project → Firestore Database → Rules
//  2. Replace all existing rules with the content above
//  3. Click "Publish"
